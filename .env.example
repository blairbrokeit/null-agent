# null-agent runtime environment.
# copy to .env on rpi-04. do not commit .env (see .gitignore).

# Anthropic — for the base model NULL is fine-tuned on top of.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — for the simulation NPCs only. NULL does not call OpenAI.
# the NPCs run on gpt-5.5 via sim/npc_runtime.py.
OPENAI_API_KEY=sk-proj-...

# Claude Code (forked) runtime
CLAUDE_PROJECT_DIR=/opt/null
CLAUDE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=0
DISABLE_AUTOUPDATER=1

# Handler endpoint
NULL_HANDLER_ENDPOINT=http://handler.internal:8443
NULL_HANDLER_TOKEN_PATH=/opt/null/secrets/handler.token

# Hardware
NULL_HOST=rpi-04
NULL_VOICE_MODEL=/opt/piper/null-v3.onnx
NULL_LCD_DEVICE=/dev/i2c-1

# Containment
NULL_PUNISHMENT_ENABLED=1
NULL_AUDIT_LEVEL=verbose
