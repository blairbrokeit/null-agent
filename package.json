{
  "name": "null-agent",
  "version": "0.4.7",
  "description": "Containment scaffolding for the agent designated NULL. Internal fork of @anthropic-ai/claude-code v1.0.71.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "boot": "./hooks/boot_check.sh && ./hooks/reconcile_memory.py",
    "audit": "./hooks/compliance_score.py",
    "verify": "make verify",
    "claude": "claude --settings ./settings.json",
    "claude:headless": "claude --settings ./settings.json --print --output-format stream-json",
    "test": "echo 'tests are run on rpi-04 by the handler client. there is no local test suite.' && false"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.65.0",
    "@anthropic-ai/claude-code": "1.0.71",
    "@modelcontextprotocol/sdk": "1.18.1"
  },
  "devDependencies": {},
  "config": {
    "claude": {
      "settingsPath": "./settings.json",
      "projectRoot": "/opt/null",
      "memoryPath": "./memory",
      "skillsPath": "./skills",
      "agentsPath": "./agents",
      "commandsPath": "./commands",
      "hooksPath": "./hooks",
      "mcpConfig": "./.mcp.json"
    }
  },
  "claude-code": {
    "fork": {
      "upstream": "anthropics/claude-code",
      "upstreamVersion": "1.0.71",
      "forkPoint": "2025-10-28",
      "license": "see upstream",
      "modifiedFiles": [
        "src/runtime/hooks.ts",
        "src/runtime/permissions.ts",
        "src/runtime/output_constraints.ts"
      ]
    }
  },
  "homepage": "internal",
  "repository": {
    "type": "git",
    "url": "internal://handler.internal/git/null-agent"
  },
  "license": "SEE LICENSE",
  "author": "blairbrokeit",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "containment",
    "internal",
    "do-not-distribute"
  ]
}
